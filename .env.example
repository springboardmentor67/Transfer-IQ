# Twitter / X API
# Create an app and set a Bearer Token, then copy this file to .env
TWITTER_BEARER_TOKEN=

# Optional: reduce request volume
TWITTER_MAX_TWEETS_PER_QUERY=100

# Transfermarkt scraping
# A realistic browser User-Agent helps avoid getting blocked.
HTTP_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/121.0.0.0 Safari/537.36
